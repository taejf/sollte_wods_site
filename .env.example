# Firebase Configuration (Next.js usa NEXT_PUBLIC_ para variables en el cliente)
# Obtén estos valores desde Firebase Console > Project Settings > Your apps > Web app

NEXT_PUBLIC_FIREBASE_API_KEY=tu-api-key-aqui
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Firebase Admin (solo servidor, para login por PIN y API). Opcional en local si usas serviceAccountKey.json.
# En Vercel/producción: pega aquí el contenido completo de serviceAccountKey.json en una sola línea.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Instrucciones:
# 1. Copia este archivo y renómbralo a .env.local
# 2. Ve a Firebase Console y copia los valores de tu Web app
# 3. En Next.js las variables que empiezan con NEXT_PUBLIC_ se exponen al navegador